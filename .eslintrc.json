{
    "env": {
      "es2021": true,
      "node": true,
      "cypress/globals": true
    },
    "extends": [
      "eslint:recommended",
      "plugin:cypress/recommended",
      "plugin:prettier/recommended"
    ],
    "plugins": ["cypress", "prettier"],
    "rules": {
      "prettier/prettier": "error",
      "no-unused-vars": "warn",
      "no-console": "off"
    }
  }